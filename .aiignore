# Context Protection - Folders and files to ignore

# Dependencies
node_modules/

# Build outputs
dist/
build/
.next/
out/
.vercel/

# Environment variables
.env
.env.*
!.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Lock files (Too large, AI doesn't need to read line by line)
package-lock.json
yarn.lock
pnpm-lock.yaml

# OS and IDE files
.DS_Store
.vscode/
.idea/
.git/

# Large assets
public/assets/
src/assets/images/
